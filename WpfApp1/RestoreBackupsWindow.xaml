<Window x:Class="QuickSticky.RestoreBackupsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restore Backups"
        Width="460"
        Height="520"
        MinWidth="380"
        MinHeight="320"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="#01000000"
        WindowStartupLocation="CenterOwner"
        SourceInitialized="Window_SourceInitialized"
        KeyDown="Window_KeyDown">

    <Window.Resources>

        <Style x:Key="GlassCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Foreground" Value="#D8FFFFFF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#10FFFFFF" />
            <Setter Property="BorderBrush" Value="#35FFFFFF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#22FFFFFF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#66FFFFFF" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BackupItemStyle" TargetType="ListBoxItem">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                CornerRadius="8"
                                Background="#10FFFFFF"
                                BorderBrush="#1FFFFFFF"
                                BorderThickness="1"
                                Padding="12,9">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1CFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#33558BFF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#6B9BFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border CornerRadius="12"
            BorderThickness="1"
            BorderBrush="#30FFFFFF"
            Background="#1A000000"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.5" />
        </Border.Effect>

        <Grid ClipToBounds="True">
            <Border CornerRadius="12" Background="#2A000000" />

            <Border Height="76"
                    VerticalAlignment="Top"
                    CornerRadius="12,12,0,0"
                    IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1EFFFFFF" Offset="0" />
                        <GradientStop Color="#06FFFFFF" Offset="0.5" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0"
                        Background="Transparent"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="20,0,12,0">
                        <TextBlock Text="Restore Backups"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="15"
                                   Foreground="#F2FFFFFF"
                                   VerticalAlignment="Center" />
                        <Button Content="✕"
                                Style="{StaticResource GlassCloseButtonStyle}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Click="Close_Click" />
                    </Grid>
                </Border>

                <TextBlock Grid.Row="1"
                           Margin="20,0,20,8"
                           Style="{StaticResource SettingsBodyText}"
                           Text="Select the notes to restore. They will reopen and move back out of Backups." />

                <!-- List -->
                <Grid Grid.Row="2" Margin="14,0,14,0">
                    <ListBox x:Name="BackupList"
                             SelectionMode="Multiple"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemContainerStyle="{StaticResource BackupItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="#F2FFFFFF"
                                               FontFamily="Segoe UI"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding DeletedDisplay}"
                                               Foreground="#9EFFFFFF"
                                               FontFamily="Segoe UI"
                                               FontSize="12"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock x:Name="EmptyMessage"
                               Visibility="Collapsed"
                               Text="There are no backups to restore."
                               Style="{StaticResource SettingsBodyText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>

                <!-- Footer -->
                <Grid Grid.Row="3" Margin="20,14,20,18">
                    <Button x:Name="RestoreButton"
                            HorizontalAlignment="Left"
                            Style="{StaticResource SettingsButton}"
                            Content="Restore selected"
                            Click="Restore_Click" />
                    <Button HorizontalAlignment="Right"
                            MinWidth="110"
                            Style="{StaticResource SettingsButton}"
                            Content="Cancel"
                            Click="Close_Click" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
