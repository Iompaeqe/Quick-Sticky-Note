<UserControl x:Class="QuickSticky.ResizableImageBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             Background="Transparent"
             HorizontalAlignment="Left"
             VerticalAlignment="Top"
             KeyDown="Root_KeyDown"
             MouseEnter="Root_MouseEnter"
             MouseLeave="Root_MouseLeave"
             MouseLeftButtonDown="Root_MouseLeftButtonDown">

    <Border x:Name="Chrome"
            Background="#06000000"
            BorderBrush="Transparent"
            BorderThickness="1"
            CornerRadius="5"
            Padding="2">
        <Grid>
            <Image x:Name="ImageElement"
                   Stretch="Fill"
                   SnapsToDevicePixels="True" />

            <Border x:Name="ResizeHandle"
                    Width="18"
                    Height="18"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="#E8FFFFFF"
                    BorderBrush="#AA000000"
                    BorderThickness="1"
                    CornerRadius="4"
                    Cursor="SizeNWSE"
                    MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                    MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"
                    MouseMove="ResizeHandle_MouseMove">
                <Grid Margin="3">
                    <Path Stroke="#99000000"
                          StrokeThickness="1.4"
                          Data="M 7 0 L 0 7" />
                    <Path Stroke="#99000000"
                          StrokeThickness="1.4"
                          Data="M 11 0 L 0 11" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
