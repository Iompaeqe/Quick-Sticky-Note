<Window x:Class="QuickSticky.NoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Note"
        Width="460"
        Height="280"
        MinWidth="260"
        MinHeight="160"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="true"
        Background="{DynamicResource AppBackgroundBrush}"
        ShowInTaskbar="False"
        LocationChanged="Window_LocationOrSizeChanged"
        SizeChanged="Window_LocationOrSizeChanged"
        Loaded="Window_Loaded"
        PreviewMouseDown="Window_PreviewMouseDown"
        KeyDown="Window_KeyDown">

    <Border Margin="0"
            CornerRadius="{DynamicResource NoteCornerRadius}"
            BorderThickness="{DynamicResource DefaultBorderThickness}"
            BorderBrush="{DynamicResource NoteBorderBrush}"
            Background="{DynamicResource NoteBackgroundBrush}"
            SnapsToDevicePixels="True">

        <Border.Effect>
            <DropShadowEffect BlurRadius="{DynamicResource NoteShadowBlurRadius}"
                              ShadowDepth="0"
                              Color="{DynamicResource ShadowColor}"
                              Opacity="{DynamicResource NoteShadowOpacity}" />
        </Border.Effect>

        <Grid ClipToBounds="True">

            <Border CornerRadius="{DynamicResource NoteCornerRadius}"
                    Background="{DynamicResource NoteSurfaceBrush}" />

            <Border Height="68"
                    VerticalAlignment="Top"
                    CornerRadius="{DynamicResource NoteHeaderCornerRadius}"
                    Background="{DynamicResource NoteHeaderOverlayBrush}"
                    IsHitTestVisible="False" />

            <Border Margin="1"
                    CornerRadius="{DynamicResource InnerCornerRadius}"
                    BorderThickness="{DynamicResource DefaultBorderThickness}"
                    BorderBrush="{DynamicResource InnerBorderBrush}"
                    IsHitTestVisible="False" />

            <Grid Margin="10,4,8,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="32" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="32" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0"
                          Margin="0,0,8,0">

                        <Grid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Settings..." Click="SettingsMenuItem_Click" />
                            </ContextMenu>
                        </Grid.ContextMenu>

                        <TextBlock x:Name="TitlePlaceholder"
                                   Text="Quick Note"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False" />

                        <TextBox x:Name="TitleEditor"
                                 TextChanged="TitleEditor_TextChanged"
                                 PreviewMouseLeftButtonDown="TitleEditor_MouseLeftButtonDown"
                                 LostFocus="TitleEditor_LostFocus"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 CaretBrush="{DynamicResource CaretBrush}"
                                 SelectionBrush="{DynamicResource SelectionBrush}"
                                 FontWeight="SemiBold"
                                 FontSize="13"
                                 FontFamily="Segoe UI"
                                 Padding="0"
                                 VerticalContentAlignment="Center" />
                    </Grid>

                    <Border Grid.Column="1"
                            Background="Transparent"
                            MouseLeftButtonDown="Window_MouseLeftButtonDown">

                        <Border.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Settings..." Click="SettingsMenuItem_Click" />
                            </ContextMenu>
                        </Border.ContextMenu>

                    </Border>

                    <Button Grid.Column="2"
                            Width="22"
                            Height="22"
                            FontSize="11"
                            Content="&#x2715;"
                            Style="{StaticResource WindowCloseButtonStyle}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="Close_Click" />
                </Grid>

                <RichTextBox x:Name="Editor"
                             Grid.Row="1"
                             Margin="0,2,0,0"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             IsDocumentEnabled="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource CaretBrush}"
                             SelectionBrush="{DynamicResource SelectionBrush}"
                             FontFamily="Consolas"
                             FontSize="14"
                             Padding="0,2,4,4"
                             PreviewKeyDown="Editor_PreviewKeyDown"
                             PreviewMouseDown="Editor_PreviewMouseDown"
                             TextChanged="Editor_TextChanged">

                    <RichTextBox.Resources>
                        <Style TargetType="{x:Type Paragraph}">
                            <Setter Property="Margin" Value="0" />
                        </Style>
                    </RichTextBox.Resources>

                    <FlowDocument Background="Transparent"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  ColumnWidth="100000"
                                  PagePadding="0">
                        <Paragraph Margin="0" />
                    </FlowDocument>

                    <RichTextBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Cut" Command="ApplicationCommands.Cut" />
                            <MenuItem Header="Copy" Command="ApplicationCommands.Copy" />
                            <MenuItem Header="Paste" Command="ApplicationCommands.Paste" />
                            <Separator />
                            <MenuItem Header="Settings..." Click="SettingsMenuItem_Click" />
                        </ContextMenu>
                    </RichTextBox.ContextMenu>

                </RichTextBox>
            </Grid>
        </Grid>
    </Border>
</Window>
