<Window x:Class="QuickSticky.RestoreBackupsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restore Backups"
        Width="460"
        Height="520"
        MinWidth="380"
        MinHeight="320"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="{DynamicResource AppBackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        SourceInitialized="Window_SourceInitialized"
        KeyDown="Window_KeyDown">

    <Border CornerRadius="{DynamicResource WindowCornerRadius}"
            BorderThickness="{DynamicResource DefaultBorderThickness}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            Background="{DynamicResource DialogBackgroundBrush}"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="{DynamicResource WindowShadowBlurRadius}"
                              ShadowDepth="0"
                              Color="{DynamicResource ShadowColor}"
                              Opacity="{DynamicResource WindowShadowOpacity}" />
        </Border.Effect>

        <Grid ClipToBounds="True">
            <Border CornerRadius="{DynamicResource WindowCornerRadius}"
                    Background="{DynamicResource WindowSurfaceBrush}" />

            <Border Height="76"
                    VerticalAlignment="Top"
                    CornerRadius="{DynamicResource WindowHeaderCornerRadius}"
                    Background="{DynamicResource WindowHeaderBrush}"
                    IsHitTestVisible="False" />

            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0"
                        Background="Transparent"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="20,0,12,0">
                        <TextBlock Text="Restore Backups"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="15"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                        <Button Content="&#x2715;"
                                Style="{StaticResource WindowCloseButtonStyle}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Click="Close_Click" />
                    </Grid>
                </Border>

                <TextBlock Grid.Row="1"
                           Margin="20,0,20,8"
                           Style="{StaticResource SettingsBodyText}"
                           Text="Select the notes to restore. They will reopen and move back out of Backups." />

                <!-- List -->
                <Grid Grid.Row="2" Margin="14,0,14,0">
                    <ListBox x:Name="BackupList"
                             SelectionMode="Multiple"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemContainerStyle="{StaticResource BackupItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontFamily="Segoe UI"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding DeletedDisplay}"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               FontFamily="Segoe UI"
                                               FontSize="12"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock x:Name="EmptyMessage"
                               Visibility="Collapsed"
                               Text="There are no backups to restore."
                               Style="{StaticResource SettingsBodyText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>

                <!-- Footer -->
                <Grid Grid.Row="3" Margin="20,14,20,18">
                    <Button x:Name="RestoreButton"
                            HorizontalAlignment="Left"
                            Style="{StaticResource SettingsButton}"
                            Content="Restore selected"
                            Click="Restore_Click" />
                    <Button HorizontalAlignment="Right"
                            MinWidth="110"
                            Style="{StaticResource SettingsButton}"
                            Content="Cancel"
                            Click="Close_Click" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
