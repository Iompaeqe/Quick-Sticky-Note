<Window x:Class="QuickSticky.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="720"
        Height="480"
        MinWidth="560"
        MinHeight="360"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="{DynamicResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        SourceInitialized="Window_SourceInitialized"
        KeyDown="Window_KeyDown">

    <Border CornerRadius="{DynamicResource WindowCornerRadius}"
            BorderThickness="{DynamicResource DefaultBorderThickness}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            Background="{DynamicResource WindowBackgroundBrush}"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="{DynamicResource WindowShadowBlurRadius}"
                              ShadowDepth="0"
                              Color="{DynamicResource ShadowColor}"
                              Opacity="{DynamicResource WindowShadowOpacity}" />
        </Border.Effect>

        <Grid ClipToBounds="True">
            <Border CornerRadius="{DynamicResource WindowCornerRadius}"
                    Background="{DynamicResource WindowSurfaceBrush}" />

            <Border Height="80"
                    VerticalAlignment="Top"
                    CornerRadius="{DynamicResource WindowHeaderCornerRadius}"
                    Background="{DynamicResource WindowHeaderBrush}"
                    IsHitTestVisible="False" />

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0"
                        Background="Transparent"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="20,0,12,0">
                        <TextBlock Text="Settings"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="15"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                        <Button Content="&#x2715;"
                                Style="{StaticResource WindowCloseButtonStyle}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Click="Close_Click" />
                    </Grid>
                </Border>

                <!-- Body -->
                <Grid Grid.Row="1" Margin="14,4,14,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="168" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="NavList"
                             Grid.Column="0"
                             Style="{StaticResource SettingsNavListStyle}"
                             DisplayMemberPath="Title"
                             SelectionChanged="NavList_SelectionChanged" />

                    <Border Grid.Column="1"
                            Margin="14,0,0,0"
                            CornerRadius="{DynamicResource WindowPanelCornerRadius}"
                            Background="{DynamicResource WindowPanelBrush}"
                            BorderBrush="{DynamicResource SurfaceBorderBrush}"
                            BorderThickness="{DynamicResource DefaultBorderThickness}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Padding="26,24">
                            <ContentControl x:Name="PageHost" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
