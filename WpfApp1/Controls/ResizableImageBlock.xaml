<UserControl x:Class="QuickSticky.ResizableImageBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             Background="Transparent"
             HorizontalAlignment="Left"
             VerticalAlignment="Top"
             KeyDown="Root_KeyDown"
             MouseEnter="Root_MouseEnter"
             MouseLeave="Root_MouseLeave"
             MouseLeftButtonDown="Root_MouseLeftButtonDown">

    <UserControl.Resources>
        <Style x:Key="DrawingToolToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="{DynamicResource DrawingToolWidth}" />
            <Setter Property="Height" Value="{DynamicResource DrawingToolHeight}" />
            <Setter Property="Margin" Value="{DynamicResource DrawingToolMargin}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="{DynamicResource DrawingToolFontSize}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource DrawingToolBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DrawingToolBorderBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource DefaultBorderThickness}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource SmallControlCornerRadius}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource DrawingToolHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource DrawingToolCheckedBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DrawingToolCheckedForegroundBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource DrawingToolCheckedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderTrackButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Background" Value="{DynamicResource SliderTrackBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Height="4"
                                VerticalAlignment="Center"
                                CornerRadius="2"
                                Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderTrackActiveButtonStyle"
               TargetType="{x:Type RepeatButton}"
               BasedOn="{StaticResource SliderTrackButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource SliderTrackActiveBrush}" />
        </Style>

        <Style x:Key="SliderThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="Root"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="7"
                                Background="{DynamicResource SliderThumbBrush}"
                                BorderBrush="{DynamicResource ResizeHandleBorderBrush}"
                                BorderThickness="{DynamicResource DefaultBorderThickness}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="5"
                                                  ShadowDepth="0"
                                                  Color="{DynamicResource ShadowColor}"
                                                  Opacity="0.35" />
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SliderThumbPressedBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AnnotationSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Height" Value="22" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid Height="{TemplateBinding Height}">
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                  Style="{StaticResource SliderTrackActiveButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                  Style="{StaticResource SliderTrackButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Orientation="Vertical">
        <Border x:Name="DrawingToolbar"
                HorizontalAlignment="Left"
                Margin="0,0,0,4"
                Padding="{DynamicResource DrawingToolbarPadding}"
                Background="{DynamicResource DrawingToolbarBackgroundBrush}"
                BorderBrush="{DynamicResource DrawingToolbarBorderBrush}"
                BorderThickness="{DynamicResource DefaultBorderThickness}"
                CornerRadius="{DynamicResource DrawingToolbarCornerRadius}"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border x:Name="ColorGradient"
                        Width="112"
                        Height="19"
                        Margin="0,0,7,0"
                        BorderBrush="{DynamicResource ButtonHoverBorderBrush}"
                        BorderThickness="{DynamicResource DefaultBorderThickness}"
                        CornerRadius="{DynamicResource SmallControlCornerRadius}"
                        Cursor="Cross"
                        SizeChanged="ColorGradient_SizeChanged"
                        MouseLeftButtonDown="ColorGradient_MouseLeftButtonDown"
                        MouseLeftButtonUp="ColorGradient_MouseLeftButtonUp"
                        MouseMove="ColorGradient_MouseMove">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#FFFF4F4F" Offset="0" />
                            <GradientStop Color="#FFFFD84D" Offset="0.17" />
                            <GradientStop Color="#FF7CFF8A" Offset="0.34" />
                            <GradientStop Color="#FF62D2FF" Offset="0.51" />
                            <GradientStop Color="#FF8E78FF" Offset="0.68" />
                            <GradientStop Color="#FFFF67D8" Offset="0.84" />
                            <GradientStop Color="#FFFFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid IsHitTestVisible="False">
                        <Border x:Name="ColorMarker"
                                Width="7"
                                Height="21"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="{DynamicResource SliderThumbBrush}"
                                BorderBrush="{DynamicResource ResizeHandleGlyphBrush}"
                                BorderThickness="{DynamicResource DefaultBorderThickness}"
                                CornerRadius="3" />
                    </Grid>
                </Border>

                <ToggleButton x:Name="EraserToggle"
                              Style="{StaticResource DrawingToolToggleStyle}"
                              ToolTip="Eraser"
                              Checked="EraserToggle_Changed"
                              Unchecked="EraserToggle_Changed">
                    <Viewbox Width="14" Height="14">
                        <Grid Width="16" Height="16">
                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}}}"
                                  Data="M 2 10 L 9 3 L 14 8 L 7 15 L 2 15 Z" />
                            <Path Stroke="{DynamicResource ResizeHandleGlyphBrush}"
                                  StrokeThickness="1"
                                  Data="M 5.5 6.5 L 10.5 11.5 M 7 15 L 14 15" />
                        </Grid>
                    </Viewbox>
                </ToggleButton>

                <TextBlock Text="Size"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,5,0" />
                <Slider x:Name="PenSizeSlider"
                        Width="64"
                        Minimum="1"
                        Maximum="12"
                        Value="3"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        IsMoveToPointEnabled="True"
                        VerticalAlignment="Center"
                        Style="{StaticResource AnnotationSliderStyle}"
                        ValueChanged="PenSizeSlider_ValueChanged" />
                <TextBlock x:Name="PenSizeText"
                           Text="3"
                           Width="16"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="11"
                           TextAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="3,0,0,0" />
            </StackPanel>
        </Border>

        <Border x:Name="Chrome"
                Background="{DynamicResource ImageChromeBackgroundBrush}"
                BorderBrush="{DynamicResource ImageChromeBorderBrush}"
                BorderThickness="{DynamicResource DefaultBorderThickness}"
                CornerRadius="{DynamicResource SmallControlCornerRadius}"
                Padding="2">
            <Grid x:Name="ImageSurface">
                <Image x:Name="ImageElement"
                       Stretch="Fill"
                       SnapsToDevicePixels="True" />

                <InkCanvas x:Name="InkOverlay"
                           Background="Transparent"
                           EditingMode="None"
                           Focusable="True"
                           KeyDown="Root_KeyDown"
                           IsHitTestVisible="False" />

                <Button x:Name="PenButton"
                        Width="24"
                        Height="24"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,4,4,0"
                        Cursor="Hand"
                        Content="&#x270E;"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Background="{DynamicResource ChromeButtonBackgroundBrush}"
                        BorderBrush="{DynamicResource ChromeButtonBorderBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Click="PenButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource SmallControlCornerRadius}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource ChromeButtonHoverBrush}" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource ChromeButtonHoverBorderBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource ChromeButtonPressedBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource DrawingToolCheckedForegroundBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Border x:Name="ResizeHandle"
                        Width="18"
                        Height="18"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Background="{DynamicResource ResizeHandleBackgroundBrush}"
                        BorderBrush="{DynamicResource ResizeHandleBorderBrush}"
                        BorderThickness="{DynamicResource DefaultBorderThickness}"
                        CornerRadius="{DynamicResource TinyControlCornerRadius}"
                        Cursor="SizeNWSE"
                        MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                        MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"
                        MouseMove="ResizeHandle_MouseMove">
                    <Grid Margin="3">
                        <Path Stroke="{DynamicResource ResizeHandleGlyphBrush}"
                              StrokeThickness="1.4"
                              Data="M 7 0 L 0 7" />
                        <Path Stroke="{DynamicResource ResizeHandleGlyphBrush}"
                              StrokeThickness="1.4"
                              Data="M 11 0 L 0 11" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
