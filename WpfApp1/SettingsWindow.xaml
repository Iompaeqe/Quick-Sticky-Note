<Window x:Class="QuickSticky.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="720"
        Height="480"
        MinWidth="560"
        MinHeight="360"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="#01000000"
        WindowStartupLocation="CenterScreen"
        SourceInitialized="Window_SourceInitialized"
        KeyDown="Window_KeyDown">

    <Window.Resources>

        <Style x:Key="GlassCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Foreground" Value="#D8FFFFFF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#10FFFFFF" />
            <Setter Property="BorderBrush" Value="#35FFFFFF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#22FFFFFF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#66FFFFFF" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#35FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Foreground" Value="#D2FFFFFF" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                CornerRadius="8"
                                Background="Transparent"
                                Padding="14,0">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#18FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2EFFFFFF" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource NavItemStyle}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <ItemsPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border CornerRadius="12"
            BorderThickness="1"
            BorderBrush="#30FFFFFF"
            Background="#1A000000"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40"
                              ShadowDepth="0"
                              Opacity="0.5" />
        </Border.Effect>

        <Grid ClipToBounds="True">
            <Border CornerRadius="12"
                    Background="#2A000000" />

            <Border Height="80"
                    VerticalAlignment="Top"
                    CornerRadius="12,12,0,0"
                    IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1EFFFFFF" Offset="0" />
                        <GradientStop Color="#06FFFFFF" Offset="0.5" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0"
                        Background="Transparent"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="20,0,12,0">
                        <TextBlock Text="Settings"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="15"
                                   Foreground="#F2FFFFFF"
                                   VerticalAlignment="Center" />
                        <Button Content="✕"
                                Style="{StaticResource GlassCloseButtonStyle}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Click="Close_Click" />
                    </Grid>
                </Border>

                <!-- Body -->
                <Grid Grid.Row="1" Margin="14,4,14,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="168" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="NavList"
                             Grid.Column="0"
                             Style="{StaticResource NavListStyle}"
                             DisplayMemberPath="Title"
                             SelectionChanged="NavList_SelectionChanged" />

                    <Border Grid.Column="1"
                            Margin="14,0,0,0"
                            CornerRadius="10"
                            Background="#16FFFFFF"
                            BorderBrush="#20FFFFFF"
                            BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Padding="26,24">
                            <ContentControl x:Name="PageHost" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
