<UserControl x:Class="QuickSticky.BackupSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="Page_Loaded">
    <StackPanel>
        <TextBlock Style="{StaticResource SettingsSectionTitle}" Text="Backups" />

        <Border Style="{StaticResource SettingsInfoCard}">
            <TextBlock Style="{StaticResource SettingsBodyText}"
                       Text="Backups are created automatically whenever you delete a note. To restore one, double-click any backed-up note to open it again." />
        </Border>

        <!-- Enable auto backups -->
        <Grid Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <TextBlock Style="{StaticResource SettingsLabel}"
                           Text="Enable automatic backups" />
                <TextBlock Style="{StaticResource SettingsBodyText}"
                           Margin="0,3,0,0"
                           Text="When off, deleting a note removes it instantly with no way to restore it." />
            </StackPanel>

            <CheckBox x:Name="AutoBackupToggle"
                      Grid.Column="1"
                      Style="{StaticResource SettingsToggle}"
                      VerticalAlignment="Center"
                      Click="AutoBackupToggle_Click" />
        </Grid>

        <Button x:Name="RestoreButton"
                Style="{StaticResource SettingsButton}"
                Margin="0,24,0,0"
                Content="Restore backups…"
                Click="RestoreBackups_Click" />

        <Button x:Name="OpenFolderButton"
                Style="{StaticResource SettingsButton}"
                Margin="0,10,0,0"
                Content="Open backups folder"
                Click="OpenFolder_Click" />

        <Button x:Name="DeleteAllButton"
                Style="{StaticResource SettingsDangerButton}"
                Margin="0,10,0,0"
                Content="Delete all backups"
                Click="DeleteAll_Click" />
    </StackPanel>
</UserControl>
