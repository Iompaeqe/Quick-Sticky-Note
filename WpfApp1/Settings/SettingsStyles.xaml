<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Shared visual language for settings pages. Pages reference these by key. -->

    <Style x:Key="SettingsSectionTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#F4FFFFFF" />
        <Setter Property="FontFamily" Value="Segoe UI Semibold" />
        <Setter Property="FontSize" Value="21" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <Style x:Key="SettingsLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#F0FFFFFF" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SettingsBodyText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#B6FFFFFF" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="19" />
    </Style>

    <Style x:Key="SettingsInfoCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="9" />
        <Setter Property="Background" Value="#14FFFFFF" />
        <Setter Property="BorderBrush" Value="#22FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,12" />
    </Style>

    <Style x:Key="SettingsButton" TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="170" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Foreground" Value="#F2FFFFFF" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="Background" Value="#18FFFFFF" />
        <Setter Property="BorderBrush" Value="#35FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#28FFFFFF" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="#5FFFFFFF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#38FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SettingsDangerButton" TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="170" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Foreground" Value="#FFC7C7" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="Background" Value="#22FF5A5A" />
        <Setter Property="BorderBrush" Value="#55FF6B6B" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#3AFF5A5A" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="#88FF6B6B" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#55FF5A5A" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SettingsToggle" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Track"
                            Width="44"
                            Height="24"
                            CornerRadius="12"
                            Background="#2EFFFFFF"
                            BorderBrush="#40FFFFFF"
                            BorderThickness="1">
                        <Border x:Name="Knob"
                                Width="18"
                                Height="18"
                                CornerRadius="9"
                                HorizontalAlignment="Left"
                                Margin="2,0,0,0"
                                Background="#F2FFFFFF" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="#4C8DFF" />
                            <Setter TargetName="Track" Property="BorderBrush" Value="#6BA4FF" />
                            <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="Knob" Property="Margin" Value="0,0,2,0" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush" Value="#80FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
