<UserControl x:Class="QuickSticky.AboutSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="Page_Loaded">
    <StackPanel>
        <TextBlock Style="{StaticResource SettingsSectionTitle}" Text="About" />

        <TextBlock Style="{StaticResource SettingsLabel}" Text="Quick Sticky Note" />

        <TextBlock x:Name="VersionText"
                   Style="{StaticResource SettingsBodyText}"
                   Margin="0,8,0,0"
                   Text="Version : …" />

        <TextBlock Style="{StaticResource SettingsBodyText}" Margin="0,6,0,0">
            <Hyperlink NavigateUri="https://github.com/Iompaeqe/Quick-Sticky-Note?tab=MIT-1-ov-file"
                       Foreground="#7FB4FF"
                       RequestNavigate="Hyperlink_RequestNavigate">MIT License</Hyperlink>
        </TextBlock>

        <TextBlock Style="{StaticResource SettingsBodyText}"
                   Margin="0,6,0,0"
                   Text="Copyright © 2026 Iompaeqe(Iompa)." />

        <Button x:Name="UpdateButton"
                Style="{StaticResource SettingsButton}"
                Margin="0,24,0,0"
                Content="Checking for updates…"
                IsEnabled="False"
                Click="UpdateButton_Click" />

        <TextBlock x:Name="UpdateStatusText"
                   Style="{StaticResource SettingsBodyText}"
                   Margin="0,10,0,0"
                   Visibility="Collapsed" />
    </StackPanel>
</UserControl>
